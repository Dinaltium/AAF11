# =============================================================================
# AAF11 Nexus — ONE env file for everything (Hub, Web, Desktop, SDK).
# Copy this to `.env`. Change values here once — all three apps read this file.
# Never commit `.env` (only this `.env.example` is committed).
# =============================================================================

# -----------------------------------------------------------------------------
# THE SWITCH — the only line you flip to change mock vs real
# -----------------------------------------------------------------------------
#   test = SQLite + seeded mock data, runs fully offline, no secrets needed
#   real = Neon Postgres + live data only (requires DATABASE_URL below)
AAF11_DATA_MODE=test

# -----------------------------------------------------------------------------
# Hub
# -----------------------------------------------------------------------------
# Signs Payload auth tokens. Fine to leave for test; MUST be strong in real
# (generate: openssl rand -hex 32).
PAYLOAD_SECRET=dev-change-me-in-real-mode
# Base URL of the Hub API (used by web, desktop, and the embedded admin webview).
AAF11_HUB_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# REAL MODE ONLY — ignored while AAF11_DATA_MODE=test
# Paste your Neon connection string here, then set AAF11_DATA_MODE=real.
# -----------------------------------------------------------------------------
DATABASE_URL=
# Vercel Blob (media uploads in real mode).
BLOB_READ_WRITE_TOKEN=
# Protects GET /api/poll in real mode (sent as Bearer).
CRON_SECRET=

# -----------------------------------------------------------------------------
# Desktop app + SDK
# -----------------------------------------------------------------------------
# Member token the desktop uses for real-mode API calls (dev fallback; the app
# stores it in the OS keychain in production). Test default matches the seed.
AAF11_MEMBER_TOKEN=mbr_rafan_test0001
# For a project that embeds the SDK:
AAF11_PROJECT_KEY=proj_example_test0000
AAF11_ENVIRONMENT=development
