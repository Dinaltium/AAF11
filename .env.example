# =============================================================================
# AAF11 Nexus — Environment Contract
# Copy to .env and fill values. NEVER commit .env (see .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# THE SINGLE SWITCH: test vs real
# -----------------------------------------------------------------------------
# test = SQLite + seeded mock data, no external services, fully runnable offline.
# real = Neon Postgres + live data. Requires every "REAL MODE ONLY" var below.
AAF11_DATA_MODE=test

# -----------------------------------------------------------------------------
# Hub (Payload + Next.js)
# -----------------------------------------------------------------------------
# Secret used by Payload to sign auth tokens. Generate: openssl rand -hex 32
# A throwaway dev value is fine in test mode; MUST be strong + secret in real.
PAYLOAD_SECRET=dev_only_change_me_in_real_mode
# Public base URL of the Hub API.
AAF11_HUB_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database — REAL MODE ONLY (ignored when AAF11_DATA_MODE=test)
# -----------------------------------------------------------------------------
# Neon Postgres connection string. Test mode ignores this and uses SQLite.
DATABASE_URL=

# -----------------------------------------------------------------------------
# Media storage — REAL MODE ONLY
# -----------------------------------------------------------------------------
# Test mode stores uploads on local disk. Real mode uses Vercel Blob (or S3).
BLOB_READ_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# SDK (per project that embeds @aaf11/connector)
# -----------------------------------------------------------------------------
AAF11_PROJECT_KEY=proj_example_test0000
AAF11_MEMBER_TOKEN=mbr_example_test0000
AAF11_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Public website
# -----------------------------------------------------------------------------
# Where the public site reads the Hub public API from.
NEXT_PUBLIC_HUB_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Deferred (Phase 4 — WhatsApp bot, not built yet). Left here as a contract.
# -----------------------------------------------------------------------------
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
