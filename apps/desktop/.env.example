# Desktop app (Vite) environment. Copy to .env.
# Vite only exposes vars prefixed with VITE_.

# test = app runs fully from bundled mock fixtures, no backend needed.
# real = app reads the live Hub private API and dispatches real control actions.
VITE_AAF11_DATA_MODE=test

# Hub base URL (real mode + the embedded admin webview).
VITE_AAF11_HUB_URL=http://localhost:3000

# Member token for real-mode API calls. In production this is stored in the OS
# keychain via the app (save_token/get_token) — this env var is a dev fallback.
VITE_AAF11_MEMBER_TOKEN=mbr_rafan_test0001
